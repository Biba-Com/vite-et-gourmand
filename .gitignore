# ─────────────────────────────────────────
# Vite & Gourmand — Git ignore configuration
# ─────────────────────────────────────────

# Environment variables (passwords, API keys)
.env
.env.local

# Composer dependencies (lock file IS versioned)
vendor/

# Node modules (if used)
node_modules/

# System files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# IDE settings (personal to each developer)
.vscode/
.idea/

# Cache directories
.cache/
*.cache

# User uploads (keep folder structure with .gitkeep)
src/public/assets/uploads/*
!src/public/assets/uploads/.gitkeep

# Build artifacts
dist/
build/

# PlantUML default output folder
out/
