# ─────────────────────────────────────────
# Vite & Gourmand — Environment template
# Copy this file to .env and fill in real values
# Never commit the actual .env file (contains secrets)
# ─────────────────────────────────────────

# ─── Application ─────────────────────────
# Note: keep APP_NAME quoted because of the ampersand (&)
APP_NAME="Vite & Gourmand"
APP_ENV=development
APP_URL=http://localhost
APP_DEBUG=true

# ─── MySQL relational database ───────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vite_et_gourmand
DB_USER=root
# Set DB_PASSWORD to a secure value in production
DB_PASSWORD=

# ─── MongoDB (NoSQL) for statistics ──────
# Note: production may require credentials in URI
MONGO_URI=mongodb://localhost:27017
MONGO_DB=vite_et_gourmand_stats

# ─── Mail configuration ──────────────────
# Mailpit is used for local development testing
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=contact@vite-et-gourmand.fr
MAIL_FROM_NAME="Vite & Gourmand"

# ─── Security ────────────────────────────
# Session lifetime in minutes
SESSION_LIFETIME=120

# Minimum password length (increase in production)
PASSWORD_MIN_LENGTH=10