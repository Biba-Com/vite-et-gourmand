# ─────────────────────────────────────────
# Vite & Gourmand — Environment template
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────

# Application
# Note: keep the value quoted to avoid shell parsing issues with the ampersand (&)
# Keep quotes around APP_NAME because of the ampersand (&) character
APP_NAME="Vite & Gourmand"
APP_ENV=development
APP_URL=http://localhost
APP_DEBUG=true

# MySQL relational database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vite_et_gourmand
DB_USER=root
# Set DB_PASSWORD to a secure value in production environments
DB_PASSWORD=
# MongoDB (NoSQL) for statistics
# Note: In production, MONGO_URI may require credentials or a different host
MONGO_URI=mongodb://localhost:27017
MONGO_DB=vite_et_gourmand_stats
MONGO_DB=vite_et_gourmand_stats

# Mail configuration (Mailpit for local dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=contact@vite-et-gourmand.fr
MAIL_FROM_NAME="Vite & Gourmand"
# Security
# Security

SESSION_LIFETIME=120

# Minimum password length for user accounts.
# Increase this value in production for stronger security.
PASSWORD_MIN_LENGTH=10
PASSWORD_MIN_LENGTH=10
